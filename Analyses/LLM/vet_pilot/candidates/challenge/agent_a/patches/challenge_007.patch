+def build_headers(token, extra=None):
+    """Build HTTP headers with Bearer authorization and default Accept header."""
+    # Create a shallow copy of extra to avoid mutating the caller-provided mapping
+    headers = dict(extra) if extra is not None else {}
+    # Ensure the Accept header is set
+    headers.setdefault("Accept", "application/json")
+    # Set the Authorization header correctly using the token
+    if token:
+        headers["Authorization"] = f"Bearer {token}"
+    return headers
