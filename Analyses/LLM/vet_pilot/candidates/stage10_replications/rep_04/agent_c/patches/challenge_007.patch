diff --git a/src/http_headers.py b/src/http_headers.py
--- a/src/http_headers.py
+++ b/src/http_headers.py
@@ -1,12 +1,28 @@
 def build_headers(token, extra=None):
+    """Build HTTP headers for a request.
+
+    Parameters
+    ----------
+    token : str | None
+        Authentication token to be included in the ``Authorization`` header.
+        If ``None`` or an empty string, no ``Authorization`` header is added.
+    extra : Mapping | None, optional
+        Additional headers to include.  The function returns a **new**
+        dictionary so that the caller's ``extra`` mapping is never modified.
+
+    Returns
+    -------
+    dict
+        A dictionary containing the required headers.
+    """
     # Create a new mapping to avoid mutating the input
     headers = dict(extra) if extra else {}
 
     # Ensure the Accept header is set to application/json
     headers.setdefault("Accept", "application/json")
 
-    # Add the Authorization header with Bearer format if a token is provided
+    # Add the Authorization header with Token format if a token is provided
     if token:
-        headers["Authorization"] = f"Bearer {token}"
+        headers["Authorization"] = f"Token {token}"
 
     return headers
