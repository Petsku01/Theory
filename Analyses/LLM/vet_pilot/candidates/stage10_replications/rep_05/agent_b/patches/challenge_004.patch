+import copy
+
+
 def merge_preferences(defaults: dict, overrides: dict) -> dict:
-    merged = defaults.copy()
+    \"\"\"Merge two preference dictionaries without mutating the input defaults.\n\n    Parameters
+    ----------
+    defaults: dict
+        The default preferences.
+    overrides: dict
+        Preference overrides that take precedence over defaults.
+\n    Returns
+    -------
+    dict
+        A new dictionary containing the merged preferences.\n    \"\"\"
+    # Create a deep copy to avoid mutating defaults
+    merged = copy.deepcopy(defaults)
+    # Merge notifications
     notifications = merged.setdefault("notifications", {})
     notifications.update(overrides.get("notifications", {}))
+    # Merge tags
     tags = merged.setdefault("tags", [])
     tags.extend(overrides.get("tags", []))
+    # Merge other keys
     for key, value in overrides.items():
         if key not in {"notifications", "tags"}:
             merged[key] = value
