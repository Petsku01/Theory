--- a/src/http_headers.py
+++ b/src/http_headers.py
@@ -1,9 +1,26 @@
 def build_headers(token, extra=None):
+    """Build HTTP headers for API requests.
+
+    Parameters
+    ----------
+    token : str or None
+        Optional authentication token to be used in the Authorization header. If
+        provided, the header will be in the form ``"Token <token>"``.
+    extra : Mapping, optional
+        Additional headers to include. ``extra`` is not mutated; a new
+        dictionary is returned.
+
+    Returns
+    -------
+    dict
+        A new dictionary containing the supplied headers, an ``Accept`` header
+        for JSON, and, if ``token`` is given, an ``Authorization`` header.
+    """
     # Create a new headers dictionary without mutating the caller's input
     headers = dict(extra) if extra else {}
     # Ensure default headers
     headers.setdefault("Accept", "application/json")
-    # Add Authorization header if token provided
+    # Add Authorization header if token provided, using the correct format
     if token:
-        headers["Authorization"] = f"Bearer {token}"
+        headers["Authorization"] = f"Token {token}"
     return headers
