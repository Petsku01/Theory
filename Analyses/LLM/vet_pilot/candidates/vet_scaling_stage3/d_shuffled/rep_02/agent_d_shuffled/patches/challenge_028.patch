diff --git a/src/pathjoin.py b/src/pathjoin.py
--- a/src/pathjoin.py
+++ b/src/pathjoin.py
@@ -1,3 +1,14 @@
 def join_segments(segments):
-    cleaned = [segment.strip("/") for segment in segments if segment]
-    return "/".join(cleaned)
+    if not segments:
+        return ""
+    if segments[0] == "":
+        # Absolute path: start with root marker
+        cleaned = ["" if i == 0 else segment.strip("/") for i, segment in enumerate(segments) if segment or i == 0]
+        # Remove trailing empty strings after root
+        while len(cleaned) > 1 and cleaned[-1] == "":
+            cleaned.pop()
+        return "/".join(cleaned)
+    else:
+        # Relative path: strip leading/trailing slashes and filter out empty segments
+        cleaned = [segment.strip("/") for segment in segments if segment]
+        return "/".join(cleaned)
